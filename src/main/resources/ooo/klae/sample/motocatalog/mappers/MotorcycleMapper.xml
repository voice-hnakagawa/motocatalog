<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ooo.klae.sample.motocatalog.mappers.MotorcycleMapper">
  <resultMap id="motorcycleResultMap" type="ooo.klae.sample.motocatalog.beans.Motorcycle">
    <id property="motoNo" column="moto_no"/>
    <result property="motoName" column="moto_name"/>
    <result property="seatHeight" column="seat_height"/>
    <result property="cylinder" column="cylinder"/>
    <result property="cooling" column="cooling"/>
    <result property="price" column="price"/>
    <result property="comment" column="comment"/>
    <association property="brandId" javaType="ooo.klae.sample.motocatalog.beans.Brand">
      <id property="brandId" column="brand_id"/>
      <result property="brandName" column="brand_name"/>
    </association>
  </resultMap>

  <select id="selectAll" resultMap="motorcycleResultMap">
    SELECT
      m_motorcycle.moto_no,
      m_motorcycle.moto_name,
      m_motorcycle.seat_height,
      m_motorcycle.cylinder,
      m_motorcycle.cooling,
      m_motorcycle.price,
      m_motorcycle.comment,
      m_motorcycle.brand_id,
      m_brand.brand_name
    FROM
      m_motorcycle
      LEFT OUTER JOIN m_brand
        ON m_motorcycle.brand_id = m_brand.brand_id
    ORDER BY
      moto_no;
  </select>
</mapper>